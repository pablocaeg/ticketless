# LLM Provider — "claude" (default) or "openai"
TICKETLESS_LLM_PROVIDER=claude

# API Keys (set one based on your provider)
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Model (optional — defaults to claude-sonnet-4-6 / gpt-4o)
# TICKETLESS_MODEL=claude-sonnet-4-6

# Server
TICKETLESS_PORT=3100
TICKETLESS_CONFIDENCE_THRESHOLD=0.75
TICKETLESS_MAX_TOOL_CALLS=10

# Postgres adapter (optional)
# DATABASE_URL=postgresql://user:pass@localhost:5432/myapp
# TICKETLESS_ALLOWED_TABLES=users,orders,subscriptions

# Stripe adapter (optional)
# STRIPE_SECRET_KEY=sk_live_...
