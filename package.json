{
  "name": "ticketless",
  "version": "0.1.0",
  "description": "Self-hosted AI agent that autonomously resolves customer support tickets",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "ticketless": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && cp -r src/dashboard dist/",
    "dev": "tsx watch src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "agent",
    "customer-support",
    "ticketing",
    "helpdesk",
    "automation",
    "llm",
    "claude",
    "openai",
    "self-hosted",
    "zendesk",
    "intercom",
    "freshdesk"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_USERNAME/ticketless"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "pg": "^8.13.0"
  },
  "peerDependencies": {
    "mysql2": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "mysql2": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
